# Friday Night Movie Environment Variables

# TZ=UTC # Optional: Your local timezone

# --- External Services ---
JELLYFIN_URL=http://your-jellyfin:8096
JELLYFIN_KEY=your_jellyfin_api_key

RADARR_URL=http://your-radarr:7878
RADARR_KEY=your_radarr_api_key

TMDB_KEY=your_tmdb_api_key

# --- LLM Providers ---
# Options: gemini, groq, openrouter (default: gemini)
LLM_PROVIDER=gemini

# Google Gemini (https://aistudio.google.com/)
GEMINI_KEY=your_gemini_api_key
# GEMINI_TEST_KEY=optional_test_key_used_in_testing

# Groq (https://console.groq.com/)
# GROQ_API_KEY=your_groq_api_key

# OpenRouter (https://openrouter.ai/)
# OPENROUTER_API_KEY=your_openrouter_api_key

# --- Provider Overrides (Advanced) ---
# LLM_MODEL=llama-3.1-70b-versatile
# LLM_ENDPOINT=https://api.groq.com/openai/v1/chat/completions
